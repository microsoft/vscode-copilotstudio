<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;net10.0</TargetFrameworks>
    <AssemblyName>Microsoft.CopilotStudio.McsCore</AssemblyName>
    <RootNamespace>$(AssemblyName)</RootNamespace>
    <SignAssembly>True</SignAssembly>
    <DelaySign>True</DelaySign>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Microsoft.CopilotStudio.Sync, " />
    <InternalsVisibleTo Include="Microsoft.PowerPlatformLS.Contracts.FileLayout, " />
    <InternalsVisibleTo Include="Microsoft.PowerPlatformLS.Contracts.Internal, " />
    <InternalsVisibleTo Include="Microsoft.PowerPlatformLS.Impl.PullAgent, " />
    <InternalsVisibleTo Include="Microsoft.PowerPlatformLS.Impl.Core, " />
    <InternalsVisibleTo Include="Microsoft.PowerPlatformLS.Impl.Language.CopilotStudio, " />
    <InternalsVisibleTo Include="Microsoft.CopilotStudio.Sync.UnitTests, " />
    <InternalsVisibleTo Include="Microsoft.CopilotStudio.Sync.TestHarness, " />
    <InternalsVisibleTo Include="Microsoft.PowerPlatformLS.UnitTests, " />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Agents.ObjectModel" />
    <PackageReference Include="Microsoft.Agents.ObjectModel.PowerFx" />
  </ItemGroup>

</Project>
