# Auto-detect text files and ensure LF line endings
* text=auto eol=lf

# Explicitly declare text files
*.cs        text diff=csharp
*.csproj    text diff=xml
*.sln       text eol=crlf
*.xml       text diff=xml
*.json      text
*.yaml      text
*.yml       text
*.md        text diff=markdown
*.txt       text
*.ts        text
*.js        text
*.mjs       text
*.css       text
*.html      text diff=html

# MSBuild / .NET config
*.props     text diff=xml
*.targets   text diff=xml
*.config    text diff=xml
*.ruleset   text diff=xml
*.runsettings text diff=xml

# Shell / scripting
*.sh        text eol=lf
*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# Git / editor config
.gitignore     text
.gitattributes text
.editorconfig  text

# Binary files — do not diff or merge
*.snk       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.vsix      binary
*.zip       binary
*.nupkg     binary
